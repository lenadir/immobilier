# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────
APP_NAME="Immobilier Platform"
APP_ENV=local
APP_KEY=base64:B/yULqguk+zFjvm9wNXblxnhqcAo2YuUqJB52X0ee9Q=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────────────
# Database — points to the "db" Docker service
# ──────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=immobilier
DB_USERNAME=immobilier
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# Exposed host port (host → container 3306)
DB_PORT_EXPOSED=3306

# ──────────────────────────────────────────────────────────────────────────────
# Redis — points to the "redis" Docker service
# ──────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# Exposed host port
REDIS_PORT_EXPOSED=6379

# ──────────────────────────────────────────────────────────────────────────────
# Cache / Sessions / Queue — use Redis in Docker
# ──────────────────────────────────────────────────────────────────────────────
CACHE_STORE=file
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ──────────────────────────────────────────────────────────────────────────────
# Filesystem
# ──────────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ──────────────────────────────────────────────────────────────────────────────
# Sanctum
# ──────────────────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:80

# ──────────────────────────────────────────────────────────────────────────────
# Mail — points to the "mailpit" Docker service
# ──────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@immobilier.local"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit web UI exposed port
MAIL_PORT_UI=8025

# ──────────────────────────────────────────────────────────────────────────────
# phpMyAdmin
# ──────────────────────────────────────────────────────────────────────────────
PMA_PORT=8080

# ──────────────────────────────────────────────────────────────────────────────
# Nginx
# ──────────────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ──────────────────────────────────────────────────────────────────────────────
# Scribe — API documentation generator
# ──────────────────────────────────────────────────────────────────────────────
SCRIBE_AUTH_KEY=
